# Django (production)
DJANGO_SETTINGS_MODULE=config.settings.production
DJANGO_SECRET_KEY=replace-with-a-long-random-secret
DJANGO_DEBUG=false
DJANGO_ALLOWED_HOSTS=api.localboost.com
DJANGO_CSRF_TRUSTED_ORIGINS=https://api.localboost.com
DJANGO_CORS_ALLOWED_ORIGINS=https://client.localboost.com,https://merchant.localboost.com

# PostgreSQL
POSTGRES_DB=localboost
POSTGRES_USER=localboost
POSTGRES_PASSWORD=replace-with-strong-password
POSTGRES_HOST=127.0.0.1
POSTGRES_PORT=5432
POSTGRES_SSLMODE=prefer

# API/JWT
API_PAGE_SIZE=20
JWT_ACCESS_MINUTES=30
JWT_REFRESH_DAYS=30

# Security toggles
DJANGO_SECURE_SSL_REDIRECT=true
DJANGO_SECURE_HSTS_SECONDS=31536000
